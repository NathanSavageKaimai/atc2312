---
import { getCollection } from 'astro:content';

const slides = await getCollection('landingCarousel');
---

{slides.length > 0 && (
	<div class="carousel" aria-label="Landing image carousel">
		{slides.map((slide, i) => (
			<img
				src={slide.data.image}
				alt=""
				class:list={['carousel-slide', { active: i === 0 }]}
				data-index={i}
				aria-hidden={i !== 0}
			/>
		))}
	</div>
)}

<style>
	.carousel {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 7;
		overflow: hidden;
		border-radius: 8px;
		background: #000;
	}

	.carousel-slide {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		opacity: 0;
		transition: opacity 0.6s ease-in-out;
	}

	.carousel-slide.active {
		opacity: 1;
	}
</style>

<script>
	const slides = document.querySelectorAll<HTMLImageElement>('.carousel-slide');
	if (slides.length > 1) {
		let current = 0;
		setInterval(() => {
			slides[current].classList.remove('active');
			slides[current].setAttribute('aria-hidden', 'true');
			current = (current + 1) % slides.length;
			slides[current].classList.add('active');
			slides[current].setAttribute('aria-hidden', 'false');
		}, 3000);
	}
</script>
